{
  "manifest_version": 3,
  "name": "LeetCode Accepted Sync",
  "version": "1.0.0",
  "description": "Sync accepted LeetCode solutions to GitHub.",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
